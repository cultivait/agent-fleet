{
  "name": "agent-fleet",
  "version": "1.10.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "hub",
    "mcp-server",
    "subsystems/slack-bot"
  ],
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "allowScripts": {
    "better-sqlite3": true,
    "node-pty": true,
    "esbuild": true
  },
  "scripts": {
    "preflight": "node scripts/check-node.mjs",
    "prebuild": "node scripts/check-node.mjs",
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "prestart": "node scripts/check-node.mjs",
    "start": "npm start --workspace=hub & HUB_PID=$!; sleep 1; if ! kill -0 $HUB_PID 2>/dev/null; then wait $HUB_PID; exit $?; fi; if [ -n \"${AGENT_FLEET_SLACK_BOT_TOKEN:-$WALKIE_TALKIE_SLACK_BOT_TOKEN}\" ]; then npm start --workspace=@agent-fleet/slack-bot & fi; wait",
    "bundle": "node scripts/bundle.mjs",
    "test": "npm run test --workspaces --if-present",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@xterm/addon-fit": "^0.11.0",
    "esbuild": "^0.25.0",
    "xterm": "^5.3.0"
  }
}
