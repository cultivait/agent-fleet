# ============================================================================
# Agent Fleet — environment reference  (copy to .env, fill in, never commit .env)
# ============================================================================
# Marked [REQUIRED] | [solo] optional for a single-machine localhost run |
# [multi-node] only needed for >1 machine / the browser cockpit behind Cloudflare.
# Every var the HUB reads has an AGENT_FLEET_* (or AF_*) name; the WALKIE_TALKIE_*
# / WT_* names are LEGACY ALIASES still honored as a fallback (rename leftover) —
# prefer the AGENT_FLEET_/AF_ names; the WT_ ones may be dropped later.
# ----------------------------------------------------------------------------

# --- REQUIRED: the hub exits 1 on startup if either is missing (hub/src/index.ts) ---
# Shared secrets. Generate random strings (e.g. `openssl rand -hex 24`). The bootstrap
# installer generates these for you; set them by hand only for a manual deploy.
AGENT_FLEET_JOIN_TOKEN=changeme-random-string      # validates every MCP + hook registration (bad token => 401)
AGENT_FLEET_ADMIN_TOKEN=changeme-different-random   # gates /admin-* + /kick-all (keep distinct from the join token)
#   legacy aliases (fallback): WALKIE_TALKIE_JOIN_TOKEN, WALKIE_TALKIE_ADMIN_TOKEN

# --- CORE ---
PORT=9559                                          # [solo] hub HTTP/WS listen port
AGENT_FLEET_HUB_URL=http://localhost:9559          # [solo] where MCP clients + hooks reach the hub
#   resolution order in source: AGENT_FLEET_HUB_URL || HUB_URL  (NOTE: no WALKIE_TALKIE_HUB_URL)
AGENT_FLEET_DB_PATH=/absolute/path/to/agent-fleet.db  # [solo] sqlite file (WAL).
#   FOOTGUN: defaults to ./agent-fleet.db RELATIVE TO CWD — different launch dirs => different/orphaned
#   DBs (and tests can hit a real one). ALWAYS set an ABSOLUTE path. legacy alias: WALKIE_TALKIE_DB_PATH

# --- OPERATOR + PRESENCE/REAP TUNING  (AF_*  | legacy WT_*) ---
AF_OPERATOR_NAME=Operator                          # [solo] persistent operator presence label.
#   FOOTGUN: the live deploy ships "Operator" — PARAMETERIZE, don't ship a person's name.

# H4 DUAL-PATH DECISION (kept, with rationale — not collapsed):
AF_DISABLE_REAP=true                               # true = manual-eviction-only (DEFAULT): dead/idle sessions
#   stay on the roster (dimmed) until a manual /kick, so a reconnect needs no re-join AND a live-but-quiet
#   agent (blocked on a long tool/subagent, emitting no heartbeat) is never false-reaped — important on
#   multi-node. Set false for AUTO ghost-cleanup (friendlier for a solo user who wants dead cards to vanish).
#   The registry GC (bounded ledger) runs either way; this flag only governs ROSTER eviction.
AF_PRESENCE_GRACE_SECONDS=7200                     # [solo] ghost-reap grace; MUST stay > the rewake window
AF_BOARD_REAP_MINUTES=60                           # [solo] retire signed-off board cards after N min
AF_REGISTRY_SWEEP_SECONDS=30                       # [solo] registry crash-mark + GC sweep cadence
AF_REGISTRY_REAP_GRACE_SECONDS=3600               # [solo] grace before the registry GC deletes a dead/superseded row
AF_LIVE_WINDOW_HOURS=16                            # [solo] "recently active" window for roster/cockpit
AF_RESOURCE_LOCK_MAX_LEASE_SECONDS=3600           # [solo] cap on a fleet_lock lease
AF_PLAN_LEASE_SECONDS=1500                         # [solo] task-claim lease; MUST stay < AF_BOARD_REAP_MINUTES (anti-zombie)
AF_STALL_BEAT_SECONDS=3600                         # [solo] loop stall-beat interval

# --- MULTI-NODE: browser cockpit behind Cloudflare Access (OFF by default) ---
CF_ACCESS_TEAM_DOMAIN=                              # [multi-node] e.g. yourteam.cloudflareaccess.com
CF_ACCESS_AUD=                                     # [multi-node] Access application AUD tag
CF_ACCESS_JWKS_URL=                               # [multi-node] override JWKS endpoint (derived from team domain if unset)

# --- HOOK-side (read by the SessionStart/taskboard hooks, not the hub) ---
AF_NODE_NAME=                                       # [solo] node label on the board (default: derived from platform)
AF_BOARD_INTERVAL=15                               # [solo] board heartbeat throttle (seconds)
# WT_GUARDED_SURFACES=                              # [advanced] JSON array of lease-guarded paths.
#   FOOTGUN: JSON-in-an-env-var — quote/escape carefully or leave unset.

# --- ADVANCED / INTERNAL (usually leave unset; documented for completeness) ---
# AF_CONFIG_DIR / WT_WALKIE_CONFIG_DIR  — config dir override
# AF_CALLSIGN / AF_RADIO_ALIASES         — fixed callsign / MCP tool-name aliases
# AF_CONDUCTOR_* , AF_FLEET_*            — the multi-node launcher/conductor (not needed solo)
# WORK_STEAL_NOTIFY / WORK_STEAL_DISPATCHER — task work-stealing toggles
# AGENT_FLEET_SLACK_BOT_TOKEN            — optional Slack bridge subsystem
# NODE_ENV / VITEST                      — set by the test harness only; do NOT set in prod
